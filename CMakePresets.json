{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "windows-ninja-msvc-debug",
            "displayName": "Windows Ninja MSVC Debug",
            "description": "Windows 上使用 Ninja + MSVC 的 Debug 构建；编译器由开发者命令提示符或 PATH 提供",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/windows-ninja-msvc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "UBAANEXT_CXX_STANDARD": "17"
            },
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        {
            "name": "windows-ninja-msvc-release",
            "displayName": "Windows Ninja MSVC Release",
            "description": "Windows 上使用 Ninja + MSVC 的 Release 构建；编译器由开发者命令提示符或 PATH 提供",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/windows-ninja-msvc-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
                "VCPKG_TARGET_TRIPLET": "x64-windows-static",
                "UBAANEXT_BUILD_TESTS": "OFF",
                "UBAANEXT_CXX_STANDARD": "17"
            },
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        {
            "name": "windows-msvc-debug",
            "displayName": "Windows MSVC Debug",
            "description": "Windows 上使用 Visual Studio + MSVC 的 Debug 构建",
            "generator": "Visual Studio 18 2026",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "binaryDir": "${sourceDir}/build/windows-msvc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "UBAANEXT_CXX_STANDARD": "17"
            },
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        {
            "name": "windows-msvc-release",
            "displayName": "Windows MSVC Release",
            "description": "Windows 上使用 Visual Studio + MSVC 的 Release 构建",
            "generator": "Visual Studio 18 2026",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "binaryDir": "${sourceDir}/build/windows-msvc-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
                "VCPKG_TARGET_TRIPLET": "x64-windows-static",
                "UBAANEXT_BUILD_TESTS": "OFF",
                "UBAANEXT_CXX_STANDARD": "17"
            },
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        {
            "name": "openharmony-clang-debug",
            "displayName": "OpenHarmony clang++ Debug",
            "description": "使用 DevEco Studio OpenHarmony Native SDK 的 Debug 构建；OHOS_NATIVE_HOME 指向 native SDK 根目录",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/openharmony-clang-debug",
            "toolchainFile": "$env{OHOS_NATIVE_HOME}/build/cmake/ohos.toolchain.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "UBAANEXT_CXX_STANDARD": "17",
                "UBAANEXT_BUILD_TESTS": "OFF",
                "UBAANEXT_FETCH_DEPS": "OFF",
                "UBAANEXT_NLOHMANN_JSON_INCLUDE_DIR": "$env{UBAANEXT_NLOHMANN_JSON_INCLUDE_DIR}",
                "OHOS_STL": "c++_shared",
                "OHOS_ARCH": "arm64-v8a",
                "CMAKE_CXX_COMPILER": "$env{OHOS_NATIVE_HOME}/llvm/bin/clang++.exe"
            }
        },
        {
            "name": "openharmony-clang-cpp20-debug",
            "displayName": "OpenHarmony clang++ C++20 Debug",
            "description": "使用 DevEco Studio OpenHarmony Native SDK 的 C++20 Debug 构建；OHOS_NATIVE_HOME 指向 native SDK 根目录",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/openharmony-clang-cpp20-debug",
            "toolchainFile": "$env{OHOS_NATIVE_HOME}/build/cmake/ohos.toolchain.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "UBAANEXT_CXX_STANDARD": "20",
                "UBAANEXT_BUILD_TESTS": "OFF",
                "UBAANEXT_FETCH_DEPS": "OFF",
                "UBAANEXT_NLOHMANN_JSON_INCLUDE_DIR": "$env{UBAANEXT_NLOHMANN_JSON_INCLUDE_DIR}",
                "OHOS_STL": "c++_shared",
                "OHOS_ARCH": "arm64-v8a",
                "CMAKE_CXX_COMPILER": "$env{OHOS_NATIVE_HOME}/llvm/bin/clang++.exe"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-ninja-msvc-debug",
            "displayName": "Windows Ninja MSVC Debug",
            "configurePreset": "windows-ninja-msvc-debug",
            "configuration": "Debug"
        },
        {
            "name": "windows-ninja-msvc-release",
            "displayName": "Windows Ninja MSVC Release",
            "configurePreset": "windows-ninja-msvc-release",
            "configuration": "Release"
        },
        {
            "name": "windows-msvc-debug",
            "displayName": "Windows MSVC Debug",
            "configurePreset": "windows-msvc-debug",
            "configuration": "Debug"
        },
        {
            "name": "windows-msvc-release",
            "displayName": "Windows MSVC Release",
            "configurePreset": "windows-msvc-release",
            "configuration": "Release"
        },
        {
            "name": "openharmony-clang-debug",
            "displayName": "OpenHarmony clang++ Debug",
            "configurePreset": "openharmony-clang-debug"
        },
        {
            "name": "openharmony-clang-cpp20-debug",
            "displayName": "OpenHarmony clang++ C++20 Debug",
            "configurePreset": "openharmony-clang-cpp20-debug"
        }
    ],
    "testPresets": [
        {
            "name": "windows-ninja-msvc-debug",
            "displayName": "Windows Ninja MSVC Debug Tests",
            "configurePreset": "windows-ninja-msvc-debug",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "windows-msvc-debug",
            "displayName": "Windows MSVC Debug Tests",
            "configurePreset": "windows-msvc-debug",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "openharmony-clang-debug",
            "displayName": "OpenHarmony clang++ Debug Tests",
            "configurePreset": "openharmony-clang-debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
