UBAANEXT_LIVE=0
UBAANEXT_CLOUD=0
UBAANEXT_USERNAME=
UBAANEXT_PASSWORD=
UBAANEXT_APP_DATA_DIR=
UBAANEXT_CONNECTION_MODE=direct
UBAANEXT_LIVE_START_DATE=
UBAANEXT_LIVE_END_DATE=
UBAANEXT_LIVE_RESOURCE_DATE=
UBAANEXT_LIVE_RESOURCE_STATUS=all
UBAANEXT_LIVE_DOWNLOAD=0
UBAANEXT_LIVE_DOWNLOAD_INCLUDE=ppt
UBAANEXT_CLOUD_ROOT_KIND=user
UBAANEXT_LIVE_LEVEL=L1
UBAANEXT_CLI_PATH=
# live smoke 自动化写测试专用；CLI 手动写命令默认具备平台写能力，但仍需 --confirm/--yes/-y 或交互 y。
UBAANEXT_ALLOW_WRITE=0
UBAANEXT_CONFIRM_WRITE=0
# Cloud 可逆写 smoke 专用。默认关闭；开启前请确认账号云盘内允许创建临时目录和测试文件。
UBAANEXT_CLOUD_WRITE=0
UBAANEXT_CLOUD_WRITE_CLEAN_RECYCLE=0
# 桌面诊断可选：构建 UBAANextDesktop 后手动指向 ubaa.exe 或 ubaa-gui。
UBAANEXT_DESKTOP_PATH=
